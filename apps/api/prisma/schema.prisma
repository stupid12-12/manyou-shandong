generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum SpotCategory {
  SIGHT
  FOOD
  TRANSPORT
  EXPERIENCE
}

enum PriceUnit {
  PERSON
  COUPLE
  ITEM
  FREE
  VARIABLE
}

enum TravelMode {
  WALK
  TRANSIT
  TRAIN
  CLIMB
}

enum BudgetCategory {
  ACCOMMODATION
  TRANSPORT
  TICKET
  FOOD
  OTHER
}

enum BudgetUnit {
  PERSON
  COUPLE
  NIGHT
  TRIP
}

enum AssetType {
  MAP
  ILLUSTRATION
  SPRITE
  TEXTURE
  ICON
}

enum SourceType {
  PRICE
  HOURS
  TIDE
  TRANSPORT
  OTHER
}

model User {
  id            BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  username      String           @unique @db.VarChar(32)
  passwordHash  String           @map("password_hash") @db.VarChar(60)
  displayName   String           @map("display_name") @db.VarChar(50)
  status        UserStatus       @default(ACTIVE)
  createdAt     DateTime         @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.DateTime(3)
  refreshTokens RefreshToken[]
  progress      UserTripProgress?
  checkins      SpotCheckin[]
  @@map("users")
}

model RefreshToken {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt    @map("user_id") @db.UnsignedBigInt
  tokenHash String    @unique @map("token_hash") @db.Char(64)
  expiresAt DateTime  @map("expires_at") @db.DateTime(3)
  revokedAt DateTime? @map("revoked_at") @db.DateTime(3)
  userAgent String?   @map("user_agent") @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, expiresAt])
  @@map("refresh_tokens")
}

model City {
  id          BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  slug        String         @unique @db.VarChar(32)
  name        String         @db.VarChar(50)
  summary     String         @db.Text
  longitude   Decimal        @db.Decimal(10, 7)
  latitude    Decimal        @db.Decimal(10, 7)
  mapAssetKey String         @map("map_asset_key") @db.VarChar(255)
  viewBox     String         @map("view_box") @db.VarChar(64)
  sortOrder   Int            @map("sort_order") @db.UnsignedSmallInt
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.DateTime(3)
  days        TripDay[]
  spots       Spot[]
  routes      RouteSegment[]
  budgets     BudgetItem[]
  foods       FoodItem[]
  media       MediaAsset[]
  progresses  UserTripProgress[]
  @@index([isActive, sortOrder])
  @@map("cities")
}

model TripDay {
  id            BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  cityId        BigInt             @map("city_id") @db.UnsignedBigInt
  tripDate      DateTime           @unique @map("trip_date") @db.Date
  title         String             @db.VarChar(100)
  transportNote String?            @map("transport_note") @db.Text
  sortOrder     Int                @map("sort_order") @db.UnsignedSmallInt
  city          City               @relation(fields: [cityId], references: [id], onDelete: Restrict)
  spots         TripDaySpot[]
  progresses    UserTripProgress[]
  @@index([cityId, sortOrder])
  @@map("trip_days")
}

model Spot {
  id               BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  cityId           BigInt           @map("city_id") @db.UnsignedBigInt
  slug             String           @db.VarChar(64)
  name             String           @db.VarChar(100)
  category         SpotCategory
  mapX             Decimal          @map("map_x") @db.Decimal(8, 4)
  mapY             Decimal          @map("map_y") @db.Decimal(8, 4)
  recommendedTime  String           @map("recommended_time") @db.VarChar(100)
  durationMinutes  Int              @map("duration_minutes") @db.UnsignedSmallInt
  priceMin         Decimal?         @map("price_min") @db.Decimal(10, 2)
  priceMax         Decimal?         @map("price_max") @db.Decimal(10, 2)
  priceUnit        PriceUnit        @map("price_unit")
  openingHours     String?          @map("opening_hours") @db.VarChar(255)
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.DateTime(3)
  city             City             @relation(fields: [cityId], references: [id], onDelete: Restrict)
  days             TripDaySpot[]
  outgoingRoutes   RouteSegment[]   @relation("RouteFrom")
  incomingRoutes   RouteSegment[]   @relation("RouteTo")
  guide            SpotGuide?
  foods            SpotFoodItem[]
  media            MediaAsset[]
  sources          SourceLink[]
  checkins         SpotCheckin[]
  characterHere    UserTripProgress[]
  @@unique([cityId, slug])
  @@index([cityId, category, isActive])
  @@map("spots")
}

model TripDaySpot {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  tripDayId    BigInt   @map("trip_day_id") @db.UnsignedBigInt
  spotId       BigInt   @map("spot_id") @db.UnsignedBigInt
  visitOrder   Int      @map("visit_order") @db.UnsignedSmallInt
  plannedStart DateTime? @map("planned_start") @db.Time(0)
  plannedEnd   DateTime? @map("planned_end") @db.Time(0)
  isOptional   Boolean  @default(false) @map("is_optional")
  tripDay      TripDay  @relation(fields: [tripDayId], references: [id], onDelete: Restrict)
  spot         Spot     @relation(fields: [spotId], references: [id], onDelete: Restrict)
  @@unique([tripDayId, spotId])
  @@unique([tripDayId, visitOrder])
  @@map("trip_day_spots")
}

model RouteSegment {
  id              BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  cityId          BigInt     @map("city_id") @db.UnsignedBigInt
  fromSpotId      BigInt     @map("from_spot_id") @db.UnsignedBigInt
  toSpotId        BigInt     @map("to_spot_id") @db.UnsignedBigInt
  svgPath         String     @map("svg_path") @db.MediumText
  durationMs      Int        @map("duration_ms") @db.UnsignedInt
  travelMode      TravelMode @map("travel_mode")
  isBidirectional Boolean    @default(false) @map("is_bidirectional")
  createdAt       DateTime   @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.DateTime(3)
  city            City       @relation(fields: [cityId], references: [id], onDelete: Restrict)
  fromSpot        Spot       @relation("RouteFrom", fields: [fromSpotId], references: [id], onDelete: Restrict)
  toSpot          Spot       @relation("RouteTo", fields: [toSpotId], references: [id], onDelete: Restrict)
  @@unique([cityId, fromSpotId, toSpotId])
  @@index([toSpotId])
  @@map("route_segments")
}

model SpotGuide {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  spotId           BigInt   @unique @map("spot_id") @db.UnsignedBigInt
  transport        String   @db.Text
  highlights       Json
  photoTips        Json     @map("photo_tips")
  savingTips       Json     @map("saving_tips")
  safetyNotices    Json     @map("safety_notices")
  avoidPitfalls    Json     @map("avoid_pitfalls")
  contentUpdatedAt DateTime @map("content_updated_at") @db.DateTime(3)
  createdAt        DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  spot             Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  @@map("spot_guides")
}

model FoodItem {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  cityId          BigInt   @map("city_id") @db.UnsignedBigInt
  name            String   @db.VarChar(100)
  description     String   @db.Text
  priceMin        Decimal? @map("price_min") @db.Decimal(10, 2)
  priceMax        Decimal? @map("price_max") @db.Decimal(10, 2)
  recommendedArea String?  @map("recommended_area") @db.VarChar(150)
  isActive        Boolean  @default(true) @map("is_active")
  city            City     @relation(fields: [cityId], references: [id], onDelete: Restrict)
  spots           SpotFoodItem[]
  @@unique([cityId, name])
  @@map("food_items")
}

model SpotFoodItem {
  spotId     BigInt   @map("spot_id") @db.UnsignedBigInt
  foodItemId BigInt   @map("food_item_id") @db.UnsignedBigInt
  sortOrder  Int      @default(0) @map("sort_order") @db.UnsignedSmallInt
  spot       Spot     @relation(fields: [spotId], references: [id], onDelete: Restrict)
  foodItem   FoodItem @relation(fields: [foodItemId], references: [id], onDelete: Restrict)
  @@id([spotId, foodItemId])
  @@map("spot_food_items")
}

model BudgetItem {
  id        BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  cityId    BigInt?        @map("city_id") @db.UnsignedBigInt
  category  BudgetCategory
  title     String         @db.VarChar(100)
  amountMin Decimal        @map("amount_min") @db.Decimal(10, 2)
  amountMax Decimal        @map("amount_max") @db.Decimal(10, 2)
  unit      BudgetUnit
  note      String?        @db.Text
  updatedAt DateTime       @updatedAt @map("updated_at") @db.DateTime(3)
  city      City?          @relation(fields: [cityId], references: [id], onDelete: SetNull)
  @@index([cityId, category])
  @@map("budget_items")
}

model MediaAsset {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  cityId    BigInt?   @map("city_id") @db.UnsignedBigInt
  spotId    BigInt?   @map("spot_id") @db.UnsignedBigInt
  assetType AssetType @map("asset_type")
  assetKey  String    @unique @map("asset_key") @db.VarChar(255)
  altText   String    @map("alt_text") @db.VarChar(255)
  width     Int?      @db.UnsignedInt
  height    Int?      @db.UnsignedInt
  sortOrder Int       @default(0) @map("sort_order") @db.UnsignedSmallInt
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  city      City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  spot      Spot?     @relation(fields: [spotId], references: [id], onDelete: SetNull)
  @@index([cityId, spotId, assetType])
  @@map("media_assets")
}

model SourceLink {
  id         BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  spotId     BigInt     @map("spot_id") @db.UnsignedBigInt
  sourceType SourceType @map("source_type")
  label      String     @db.VarChar(150)
  url        String     @db.VarChar(2048)
  checkedAt  DateTime   @map("checked_at") @db.DateTime(3)
  createdAt  DateTime   @default(now()) @map("created_at") @db.DateTime(3)
  spot       Spot       @relation(fields: [spotId], references: [id], onDelete: Cascade)
  @@index([spotId, sourceType, checkedAt])
  @@map("source_links")
}

model UserTripProgress {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId          BigInt   @unique @map("user_id") @db.UnsignedBigInt
  activeCityId    BigInt?  @map("active_city_id") @db.UnsignedBigInt
  activeTripDayId BigInt?  @map("active_trip_day_id") @db.UnsignedBigInt
  characterSpotId BigInt?  @map("character_spot_id") @db.UnsignedBigInt
  progressVersion Int      @default(1) @map("progress_version") @db.UnsignedInt
  updatedAt       DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeCity      City?    @relation(fields: [activeCityId], references: [id], onDelete: SetNull)
  activeTripDay   TripDay? @relation(fields: [activeTripDayId], references: [id], onDelete: SetNull)
  characterSpot   Spot?    @relation(fields: [characterSpotId], references: [id], onDelete: SetNull)
  @@map("user_trip_progress")
}

model SpotCheckin {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId      BigInt   @map("user_id") @db.UnsignedBigInt
  spotId      BigInt   @map("spot_id") @db.UnsignedBigInt
  checkedInAt DateTime @default(now()) @map("checked_in_at") @db.DateTime(3)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot        Spot     @relation(fields: [spotId], references: [id], onDelete: Restrict)
  @@unique([userId, spotId])
  @@index([userId, checkedInAt])
  @@map("spot_checkins")
}
