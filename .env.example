# 开发环境
NODE_ENV=development
PORT=8787
WEB_ORIGIN=http://localhost:5173

# 演示模式：不需要 MySQL，数据存储在 API 进程内存中
DEMO_MODE=true

# MySQL 模式（可选，需 Docker）
# DATABASE_URL=mysql://manyou:manyou@localhost:3306/manyou_shandong

# 生产环境务必修改以下密钥
JWT_ACCESS_SECRET=replace-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-another-32-character-secret
